#include <stdio.h>

// Recursive Function
long long recursiveFactorial(int n)
{
    if(n == 0 || n == 1)
        return 1;

    return n * recursiveFactorial(n - 1);
}

// Iterative Function
long long iterativeFactorial(int n)
{
    int i;
    long long fact = 1;

    for(i = 1; i <= n; i++)
        fact = fact * i;

    return fact;
}

int main()
{
    int n;

    printf("===== Memory Usage and Space Complexity =====\n");

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("\nRecursive Factorial = %lld\n", recursiveFactorial(n));
    printf("Iterative Factorial = %lld\n", iterativeFactorial(n));

    printf("\nAlgorithm Analysis\n");
    printf("--------------------------\n");
    printf("Input Size            : %d\n", n);
    printf("Recursive Time        : O(n)\n");
    printf("Recursive Space       : O(n)\n");
    printf("Iterative Time        : O(n)\n");
    printf("Iterative Space       : O(1)\n");

    return 0;
}
