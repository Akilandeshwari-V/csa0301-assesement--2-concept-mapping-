#include <stdio.h>

#define MAX 100

// Linear Search
int linearSearch(int arr[], int n, int key)
{
    int i;

    for(i = 0; i < n; i++)
    {
        if(arr[i] == key)
            return i;
    }

    return -1;
}

// Binary Search
int binarySearch(int arr[], int n, int key)
{
    int low = 0, high = n - 1, mid;

    while(low <= high)
    {
        mid = (low + high) / 2;

        if(arr[mid] == key)
            return mid;

        else if(arr[mid] < key)
            low = mid + 1;

        else
            high = mid - 1;
    }

    return -1;
}

int main()
{
    int arr[MAX];
    int n, i, key;
    int result;

    printf("===== SEARCHING ALGORITHMS =====\n");

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter %d elements in sorted order:\n", n);

    for(i = 0; i < n; i++)
        scanf("%d", &arr[i]);

    printf("Enter element to search: ");
    scanf("%d", &key);

    // Linear Search
    result = linearSearch(arr, n, key);

    if(result != -1)
        printf("\nLinear Search: Element found at position %d\n", result + 1);
    else
        printf("\nLinear Search: Element not found\n");

    // Binary Search
    result = binarySearch(arr, n, key);

    if(result != -1)
        printf("Binary Search: Element found at position %d\n", result + 1);
    else
        printf("Binary Search: Element not found\n");

    printf("\nComplexity Analysis\n");
    printf("----------------------------\n");
    printf("Linear Search Time Complexity : O(n)\n");
    printf("Binary Search Time Complexity : O(log n)\n");
    printf("Space Complexity (Both)       : O(1)\n");

    return 0;
}
