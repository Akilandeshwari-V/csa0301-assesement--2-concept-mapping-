#include <stdio.h>
#include <string.h>

#define MAX 100

// Structure for Book
struct Book
{
    int bookID;
    char title[50];
    char author[50];
    char status[20];
};

struct Book library[MAX];
int count = 0;

// Add Book
void addBook()
{
    printf("\nEnter Book ID: ");
    scanf("%d", &library[count].bookID);

    printf("Enter Book Title: ");
    scanf(" %[^\n]", library[count].title);

    printf("Enter Author Name: ");
    scanf(" %[^\n]", library[count].author);

    printf("Enter Availability (Available/Issued): ");
    scanf(" %s", library[count].status);

    count++;

    printf("\nBook Added Successfully!\n");
}

// Display Books
void displayBooks()
{
    int i;

    if(count == 0)
    {
        printf("\nNo Books Available!\n");
        return;
    }

    printf("\n========== BOOK DETAILS ==========\n");

    for(i = 0; i < count; i++)
    {
        printf("\nBook %d\n", i + 1);
        printf("Book ID      : %d\n", library[i].bookID);
        printf("Title        : %s\n", library[i].title);
        printf("Author       : %s\n", library[i].author);
        printf("Availability : %s\n", library[i].status);
    }
}

// Search Book
void searchBook()
{
    int id, i, found = 0;

    printf("\nEnter Book ID to Search: ");
    scanf("%d", &id);

    for(i = 0; i < count; i++)
    {
        if(library[i].bookID == id)
        {
            found = 1;

            printf("\nBook Found!\n");
            printf("Book ID      : %d\n", library[i].bookID);
            printf("Title        : %s\n", library[i].title);
            printf("Author       : %s\n", library[i].author);
            printf("Availability : %s\n", library[i].status);

            break;
        }
    }

    if(found == 0)
        printf("\nBook Not Found!\n");
}

int main()
{
    int choice;

    while(1)
    {
        printf("\n===== LIBRARY MANAGEMENT SYSTEM =====\n");
        printf("1. Add Book\n");
        printf("2. Display Books\n");
        printf("3. Search Book\n");
        printf("4. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                addBook();
                break;

            case 2:
                displayBooks();
                break;

            case 3:
                searchBook();
                break;

            case 4:
                printf("\nThank You!\n");
                return 0;

            default:
                printf("\nInvalid Choice!\n");
        }
    }

    return 0;
}
