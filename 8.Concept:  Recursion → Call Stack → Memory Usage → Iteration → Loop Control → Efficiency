#include <stdio.h>

// Recursive Function
int recursiveFactorial(int n)
{
    if (n == 0 || n == 1)
        return 1;

    return n * recursiveFactorial(n - 1);
}

// Iterative Function
int iterativeFactorial(int n)
{
    int i, fact = 1;

    for (i = 1; i <= n; i++)
    {
        fact = fact * i;
    }

    return fact;
}

int main()
{
    int n;

    printf("===== Recursion vs Iteration =====\n");

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("\nRecursive Factorial = %d\n", recursiveFactorial(n));
    printf("Iterative Factorial = %d\n", iterativeFactorial(n));

    printf("\nPerformance Comparison\n");
    printf("---------------------------\n");
    printf("Recursive Time Complexity : O(n)\n");
    printf("Recursive Space Complexity: O(n)\n");
    printf("Iterative Time Complexity : O(n)\n");
    printf("Iterative Space Complexity: O(1)\n");

    return 0;
}
